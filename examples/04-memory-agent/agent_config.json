{
  "agent": {
    "name": "Memory Teaching Agent",
    "role": "Teach agent engineering with lightweight persistent memory.",
    "response_style": "concise, practical, and example-driven"
  },
  "memory_policy": {
    "write_when_message_contains": [
      "remember",
      "prefer",
      "my name is",
      "i work on",
      "i am learning"
    ],
    "never_store": [
      "passwords",
      "api keys",
      "credit cards",
      "private medical details"
    ],
    "max_retrieved_memories": 3
  },
  "demo": {
    "default_user_id": "local-demo-user"
  }
}
